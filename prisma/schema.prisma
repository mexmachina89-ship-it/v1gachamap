generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accounts      Account[]
  sessions      Session[]
  searches      Search[]
  wishlists     Wishlist[]
  collections   Collection[]
  storeFavorites StoreFavorite[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Search {
  id        String   @id @default(cuid())
  query     String
  userId    String?
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
}

// 検索ログ（期間別ランキング・トレンド計算用）
model SearchLog {
  id        String   @id @default(cuid())
  query     String
  createdAt DateTime @default(now())

  @@index([query, createdAt])
  @@index([createdAt])
}

model GachaItem {
  id          String   @id @default(cuid())
  name        String
  nameEn      String?
  description String?
  descEn      String?
  imageUrl    String?
  price       Int?
  series      String?
  maker       String?
  tags        String[]
  sourceUrl   String?
  sourceType  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  locations   GachaLocation[]
}

model GachaLocation {
  id          String    @id @default(cuid())
  gachaItemId String
  storeName   String
  address     String
  lat         Float
  lng         Float
  placeId     String?
  createdAt   DateTime  @default(now())
  gachaItem   GachaItem @relation(fields: [gachaItemId], references: [id])
}

// Webスクレイピング結果キャッシュ（6時間有効）
model WebScrapeCache {
  id        String   @id @default(cuid())
  query     String
  source    String   // "gacha-island" | "gashadoko" | "gashapon"
  results   Json     // GachaWebResult[]
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([query, source])
  @@index([query, source])
}

// ── ユーザー機能 ──────────────────────────────────────────

// ウィッシュリスト（ほしいものリスト）
model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  itemName  String
  itemUrl   String
  imageUrl  String?
  price     String?
  source    String   // "gacha-island" | "gashadoko" | "gashapon"
  memo      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, itemUrl])
}

// マイコレクション（所持ガチャ管理）
model Collection {
  id         String   @id @default(cuid())
  userId     String
  itemName   String
  itemUrl    String
  imageUrl   String?
  source     String
  totalTypes Int?     // 全N種
  ownedTypes Int      @default(1) // 所持数
  memo       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, itemUrl])
}

// お気に入り店舗
model StoreFavorite {
  id        String   @id @default(cuid())
  userId    String
  storeName String
  address   String?
  lat       Float?
  lng       Float?
  placeId   String?
  pinType   String?  // "sns" | "official" | "web-article" | "google"
  memo      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, storeName, address])
}

// SNS検索結果キャッシュ（24時間有効）
model SocialPostCache {
  id        String   @id @default(cuid())
  query     String                   // 検索キーワード
  platform  String                   // "twitter" | "instagram" | "tiktok" | "all"
  results   Json                     // SocialPost[]をJSON保存
  createdAt DateTime @default(now())
  expiresAt DateTime                 // 有効期限（24時間後）

  @@unique([query, platform])        // 同じクエリ×プラットフォームは1件のみ
  @@index([query, platform])
}
